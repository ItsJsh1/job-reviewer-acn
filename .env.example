# Gemini — used by /api/grade and /api/transcribe. Get a free key (no
# credit card needed) at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Postgres — from Supabase (via the Vercel integration) or plain Supabase/
# Vercel Postgres. Only needed once you move past the hardcoded-data MVP
# stage. DATABASE_URL is the pooled connection the app uses at runtime;
# DIRECT_URL is the non-pooled connection used only for migrations/seeding.
# If you're using the Vercel Supabase integration, these correspond to the
# POSTGRES_PRISMA_URL and POSTGRES_URL_NON_POOLING variables it creates.
DATABASE_URL=postgres://user:password@host:6543/dbname?pgbouncer=true
DIRECT_URL=postgres://user:password@host:5432/dbname

# Simple PIN/password gate for the /admin route
ADMIN_PASSWORD=choose-something-only-you-know
